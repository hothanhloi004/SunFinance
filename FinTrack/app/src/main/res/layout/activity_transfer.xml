<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#F7F8FA"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- HEADER -->
        <TextView
            android:text="Internal Transfer"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Move Funds"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Transfer money instantly between your SunFinance wallets."
            android:textColor="#777777"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- FROM WALLET LABEL -->
        <TextView
            android:text="FROM WALLET"
            android:textColor="#999999"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- FROM WALLET CARD -->
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="vertical"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvSourceAccount"
                    android:text="Spending Account"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvSourceBalance"
                    android:text="Balance: 10,000,000 VND"
                    android:textColor="#777777"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/btnChangeSource"
                    android:text="Change"
                    android:textSize="12sp"
                    android:background="@drawable/bg_toggle"
                    android:layout_marginTop="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"/>
            </LinearLayout>

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_orange_icon">

                <TextView
                    android:text="💼"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </FrameLayout>

        </LinearLayout>

        <!-- FLOW -->
        <TextView
            android:text="TRANSACTION FLOW"
            android:textSize="11sp"
            android:textColor="#BBBBBB"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- TO WALLET LABEL -->
        <TextView
            android:text="TO WALLET"
            android:textColor="#999999"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- TO WALLET CARD -->
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="vertical"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvTargetAccount"
                    android:text="Savings Vault"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvTargetBalance"
                    android:text="Balance: 50,000,000 VND"
                    android:textColor="#777777"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/btnChangeTarget"
                    android:text="Change"
                    android:textSize="12sp"
                    android:background="@drawable/bg_toggle"
                    android:layout_marginTop="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"/>
            </LinearLayout>

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_blue_icon">

                <TextView
                    android:text="🐷"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </FrameLayout>

        </LinearLayout>

        <!-- AMOUNT CARD -->
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="AMOUNT TO TRANSFER"
                android:textColor="#999999"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/edtAmount"
                android:text="VND 2,500,000"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@null"
                android:layout_marginTop="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- PRESET -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btn500k"
                android:text="+500k"
                android:background="@drawable/bg_toggle"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="36dp"/>

            <Button
                android:id="@+id/btn1m"
                android:text="+1M"
                android:background="@drawable/bg_toggle"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="36dp"/>

            <Button
                android:id="@+id/btn5m"
                android:text="+5M"
                android:background="@drawable/bg_toggle"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="36dp"/>
        </LinearLayout>

        <!-- FEE -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginBottom="6dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Transaction Fee"
                android:textColor="#777777"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="FREE"
                android:textColor="#00C853"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginBottom="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Estimated Arrival"
                android:textColor="#777777"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Instant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <EditText
            android:id="@+id/edtNote"
            android:hint="Ghi chú (optional)"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>
        <!-- CONFIRM -->
        <Button
            android:id="@+id/btnTransfer"
            android:text="Confirm Transfer →"
            android:textStyle="bold"
            android:textColor="#000000"
            android:background="@drawable/bg_button_yellow"
            android:layout_width="match_parent"
            android:layout_height="56dp"/>

    </LinearLayout>
</ScrollView>