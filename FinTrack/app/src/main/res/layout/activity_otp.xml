<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9F9">

    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="-80dp"
        android:layout_marginEnd="-60dp"
        android:background="#FFC107" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_sun"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SunFinance"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="30dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter OTP"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="We've sent a 8-digit code to your registered email for your account."
            android:gravity="center"
            android:textColor="#777777"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/txtTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mã hết hạn sau: 05:00"
            android:textColor="#FF5722"
            android:textStyle="italic"
            android:textSize="14sp"
            android:layout_marginBottom="25dp"/>

        <LinearLayout
            android:id="@+id/layoutOtpBoxes"
            android:layout_width="398dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvOtp1"
                style="@style/OtpBoxStyle" />

            <TextView
                android:id="@+id/tvOtp2"
                style="@style/OtpBoxStyle" />

            <TextView
                android:id="@+id/tvOtp3"
                style="@style/OtpBoxStyle" />

            <TextView
                android:id="@+id/tvOtp4"
                style="@style/OtpBoxStyle" />

            <TextView
                android:id="@+id/tvOtp5"
                style="@style/OtpBoxStyle" />

            <TextView
                android:id="@+id/tvOtp6"
                style="@style/OtpBoxStyle" />

            <TextView
                android:id="@+id/tvOtp7"
                style="@style/OtpBoxStyle" />

            <TextView
                android:id="@+id/tvOtp8"
                style="@style/OtpBoxStyle" />
        </LinearLayout>

        <EditText
            android:id="@+id/edtHiddenOtp"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:alpha="0"
            android:inputType="number"
            android:maxLength="8" />

        <Button
            android:id="@+id/btnVerify"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="40dp"
            android:backgroundTint="#FFC107"
            android:text="VERIFY"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>
</RelativeLayout>