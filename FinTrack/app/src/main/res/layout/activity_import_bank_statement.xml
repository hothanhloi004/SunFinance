<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/outline_arrow_back_24"
                android:contentDescription="back"
                app:tint="#111827"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Import Bank Statement"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_centerInParent="true"/>

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/outline_help_24"
                android:contentDescription="help"
                app:tint="#111827"/>
        </RelativeLayout>

        <!-- UPLOAD BOX -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_dashed"
            android:padding="20dp">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/outline_cloud_upload_24"
                android:contentDescription="upload"
                app:tint="#16A34A"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload Statement"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_marginTop="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Drag and drop your Excel or CSV file here, or browse your files"
                android:textSize="15sp"
                android:textColor="#6B7280"
                android:gravity="center"
                android:layout_marginTop="6dp"/>

            <Button
                android:id="@+id/btnSelectFile"
                android:layout_width="160dp"
                android:layout_height="48dp"
                android:text="Select File"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_button_green"/>

            <TextView
                android:id="@+id/txtFileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No file selected"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- MAPPING TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mapping Preview"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_marginTop="24dp"/>

        <!-- MAPPING CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="10dp">

            <!-- DATE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Date"
                    android:textStyle="bold"
                    android:textColor="#111827"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textColor="#6B7280"/>

                <TextView
                    android:id="@+id/txtPreviewDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="-"
                    android:textStyle="bold"
                    android:textColor="#111827"/>
            </LinearLayout>

            <!-- AMOUNT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Amount"
                    android:textStyle="bold"
                    android:textColor="#111827"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textColor="#6B7280"/>

                <TextView
                    android:id="@+id/txtPreviewAmount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="-"
                    android:textStyle="bold"
                    android:textColor="#111827"/>
            </LinearLayout>

            <!-- DESCRIPTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Description"
                    android:textStyle="bold"
                    android:textColor="#111827"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textColor="#6B7280"/>

                <TextView
                    android:id="@+id/txtPreviewNote"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="-"
                    android:textStyle="bold"
                    android:textColor="#111827"/>
            </LinearLayout>

        </LinearLayout>

        <!-- DUPLICATE CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Duplicate Detection"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#111827"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="We will automatically skip transactions that have already been imported."
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:layout_marginTop="6dp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchDuplicate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:layout_marginTop="10dp"
                app:thumbTint="#16A34A"
                app:trackTint="#86EFAC"/>
        </LinearLayout>

        <!-- START IMPORT BUTTON -->
        <Button
            android:id="@+id/btnStartImport"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Start Import →"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_green"/>

    </LinearLayout>

</ScrollView>