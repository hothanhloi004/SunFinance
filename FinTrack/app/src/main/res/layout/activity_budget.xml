<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A8D5BA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Budget &amp; Limits"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1B4332"
            android:layout_marginBottom="16dp"/>

        <!-- TOTAL CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#CFF3E4"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:text="Total Monthly Budget Spent"
                    android:textSize="13sp"
                    android:textColor="#52796F"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvTotalSpent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 VND"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#081C15"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:text="SunFinance: Keep your savings bright."
                    android:textSize="12sp"
                    android:textColor="#52796F"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ACTIVE HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Active Budgets"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1B4332"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit All"
                android:textColor="#00C853"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- EXISTING BUDGET ITEMS -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvBudgets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <!-- SET NEW LIMIT CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#F1F3F4"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="30dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- TITLE -->
                <TextView
                    android:text="Set New Limit"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- CATEGORY -->
                <TextView
                    android:text="CATEGORY"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <Spinner
                    android:id="@+id/spCategory"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@android:drawable/editbox_background"
                    android:padding="10dp"
                    android:layout_marginBottom="16dp"/>

                <!-- AMOUNT + PERIOD -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <!-- AMOUNT -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:text="AMOUNT (VND)"
                            android:textSize="11sp"
                            android:textColor="#888888"
                            android:layout_marginBottom="6dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <EditText
                            android:id="@+id/etAmount"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="0.00"
                            android:inputType="number"
                            android:background="@android:drawable/editbox_background"
                            android:padding="10dp"/>
                    </LinearLayout>

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="wrap_content"/>

                    <!-- PERIOD -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:text="PERIOD"
                            android:textSize="11sp"
                            android:textColor="#888888"
                            android:layout_marginBottom="6dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <Spinner
                            android:id="@+id/spPeriod"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@android:drawable/editbox_background"
                            android:padding="10dp"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- CHECKBOX -->
                <CheckBox
                    android:id="@+id/cbNotify"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notify me when I reach 80%"
                    android:layout_marginBottom="20dp"/>

                <!-- BUTTON -->
                <Button
                    android:id="@+id/btnCreate"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="➕  Create Budget Limit"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:background="@drawable/rounded_button_green"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>